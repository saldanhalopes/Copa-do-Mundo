{
  "name": "cryptoalbum-copa",
  "version": "1.0.0",
  "description": "Plataforma de álbum de figurinhas da Copa em NFT — jogo de cartas PvP",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:amoy": "hardhat run scripts/deploy-testnet.js --network amoy",
    "deploy:bsctest": "hardhat run scripts/deploy-testnet.js --network bscTestnet",
    "vrf:create:amoy": "hardhat run scripts/create-vrf-subscription.js --network amoy",
    "vrf:create:bsc": "hardhat run scripts/create-vrf-subscription.js --network bscTestnet",
    "vrf:add-consumer:amoy": "hardhat run scripts/manage-vrf-consumer.js --network amoy",
    "vrf:add-consumer:bsc": "hardhat run scripts/manage-vrf-consumer.js --network bscTestnet",
    "gen:cards": "cd generator && python3 generate_cards.py"
  },
  "devDependencies": {
    "@chainlink/contracts": "^1.2.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ethereumjs/common": "^4.4.0",
    "@ethereumjs/tx": "^5.4.0",
    "@ethereumjs/util": "^9.1.0",
    "@ethereumjs/vm": "^7.2.1",
    "ethers": "^6.16.0",
    "solc": "^0.8.24"
  }
}
