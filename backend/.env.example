# Servidor
PORT=3001
NODE_ENV=development

# Redis (opcional — usado para cache de sessão/fila distribuída)
REDIS_URL=

# Autenticação
JWT_SECRET=dev-secret-change-in-prod

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Banco SQLite local
DATABASE_URL=./data/copa.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# RPCs on-chain
RPC_POLYGON=https://polygon-amoy.g.alchemy.com/v2/demo
RPC_BSC=https://data-seed-prebsc-1-s1.binance.org:8545

# API esportiva (oráculo)
SPORTS_API_KEY=
SPORTS_API_BASE_URL=https://v3.football.api-sports.io

# Endereços dos contratos implantados
CONTRACT_PACK_STORE=
CONTRACT_MATCH_ESCROW=
CONTRACT_RANKING=

# Verificação de idade (on-chain age verifier)
AGE_VERIFIER_PRIVATE_KEY=
MIN_AGE_STAKED_PVP=18

# KYC Provider Webhook Secrets
CROSSMINT_WEBHOOK_SECRET=
MOONPAY_WEBHOOK_SECRET=
BINANCE_PAY_KYC_SECRET=

# AML Risk Thresholds (0.0 - 1.0)
AML_RISK_THRESHOLD_LOW=0.2
AML_RISK_THRESHOLD_MEDIUM=0.5
AML_RISK_THRESHOLD_HIGH=0.8

# Wash Trading Detection
WASH_ROUND_TRIP_THRESHOLD=2
WASH_TIME_WINDOW_MINUTES=60
WASH_SAME_IP_THRESHOLD=3

# Geofencing (Bloqueio Regional)
GEOFENCE_ENFORCE_PACKS=true
GEOFENCE_ENFORCE_STAKING=false
GEOFENCE_AUDIT_LOG_MAX=10000
GEOFENCE_BLOCK_UNKNOWN=false
GEOFENCE_CONFIG_PATH=

# Contract Override (Endereços por jurisdição)
CONTRACT_OVERRIDE_ENABLED=false
CONTRACT_OVERRIDE_CACHE_TTL=300000
